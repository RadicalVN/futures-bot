# ============================================================
# Binance Trading Service — Environment Variables
# Copy file này thành .env và điền thông tin của bạn
# KHÔNG BAO GIỜ commit file .env lên git!
# ============================================================

# --- Binance API ---
# Testnet Futures: https://testnet.binancefuture.com
# Mainnet: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Chế độ: "testnet" hoặc "mainnet"
BINANCE_MODE=testnet

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
# Mật khẩu đăng nhập dashboard (để trống = không cần mật khẩu)
DASHBOARD_PASSWORD=

# --- Bot Settings ---
# true = bot sẽ tự động chạy khi start
BOT_AUTO_START=false

# --- Database ---
# SQLite (dev local):
# DATABASE_URL=sqlite+aiosqlite:///./data/trading.db
# PostgreSQL (production):
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_db

# --- Chart / Indicators ---
# Độ dài Signal Line của Custom MACD (mặc định 500 — cực mượt)
MACD_SIGNAL_LENGTH=500

# Số nến hiển thị mặc định trên biểu đồ backtest (mặc định 200)
BACKTEST_CHART_CANDLES=200

# --- Strategy: SMA MACD Cross V6 ---
# Chu kỳ ADX (mặc định 14 — chuẩn Wilder)
ADX_PERIOD=14
# Ngưỡng ADX tối thiểu để VÀO lệnh (mặc định 25)
ADX_ENTRY_THRESHOLD=25
# Ngưỡng ADX tối thiểu để ĐÓNG lệnh (mặc định 25)
ADX_EXIT_THRESHOLD=25

# --- Notifications ---
# Discord Webhook URL để nhận thông báo lệnh vào/ra (entry/exit)
# Tạo tại: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Discord Webhook URL riêng cho báo cáo định kỳ mỗi nến 5m
# Nếu để trống sẽ dùng chung DISCORD_WEBHOOK_URL ở trên
DISCORD_REPORT_WEBHOOK_URL=
