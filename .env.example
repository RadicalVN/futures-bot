# ============================================================
# Binance Trading Service — Environment Variables
# Copy file này thành .env và điền thông tin của bạn
# KHÔNG BAO GIỜ commit file .env lên git!
# ============================================================

# --- Binance API ---
# Testnet Futures: https://testnet.binancefuture.com
# Mainnet: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Chế độ: "testnet" hoặc "mainnet"
BINANCE_MODE=testnet

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
# Mật khẩu đăng nhập dashboard (để trống = không cần mật khẩu)
DASHBOARD_PASSWORD=

# --- Bot Settings ---
# true = bot sẽ tự động chạy khi start
BOT_AUTO_START=false

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# --- Notifications ---
# Discord Webhook URL để nhận thông báo lệnh vào/ra (entry/exit)
# Tạo tại: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Discord Webhook URL riêng cho báo cáo định kỳ mỗi nến 5m
# Nếu để trống sẽ dùng chung DISCORD_WEBHOOK_URL ở trên
DISCORD_REPORT_WEBHOOK_URL=
